{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Mpeg4Player",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/Mpeg4Player${command:cmake.launchTargetExtension}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build"
        }
    ]
}
